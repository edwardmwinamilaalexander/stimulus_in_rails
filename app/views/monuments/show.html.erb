<p style="color: green"><%= notice %></p>
<h3>Monument details</h3>
  <p><strong>Name: </strong> <%= @monument.name%></p>
    <p><strong>Address: </strong><%= @monument.address%></p>
      <p><strong>Opening date: </strong> <%= @monument.opening_date%></p>


<div>
  <%= link_to "Edit this monument", edit_monument_path(@monument) %> |
  <%= link_to "Back to monuments", monuments_path %>
  <%= button_to "Destroy this monument", @monument, method: :delete %>
</div>
